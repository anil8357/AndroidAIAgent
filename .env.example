# ============================================================
# Android OpenCode Agent — Environment Variables Template
#
# Copy this file to `.env` and replace every placeholder value
# with a real key before starting the services:
#
#   cp .env.example .env      (macOS/Linux)
#   copy .env.example .env    (Windows)
#
# Do NOT commit your real `.env` file or any real credentials.
# ============================================================

# Google Gemini API key — used by the `gemini/*` models.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter API key — used by all `openrouter/*` fallback models.
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq API key — used by `groq/*` models (ultra-fast LPU inference).
# Get one at: https://console.groq.com/keys
# Free tier: 30 RPM, 1K RPD, no credit card required.
GROQ_API_KEY=

# Cerebras API key — used by `cerebras/*` models (wafer-scale inference).
# Get one at: https://cloud.cerebras.ai/
# Free tier: 1M tokens/day, no credit card required.
CEREBRAS_API_KEY=

# ── LiteLLM Context/Truncation Settings (Docker path only) ──
# These prevent LiteLLM from truncating large prompts in its DB logs.
# The actual model still receives the full context regardless — these
# only affect what's stored in Postgres spend logs for the dashboard.
# Increase if you work with very large files (1000+ lines).
MAX_STRING_LENGTH_PROMPT_IN_DB=500000
MAX_STRING_LENGTH_RESPONSE_IN_DB=500000

# NaraRouter API key — used as an additional routing provider.
# Get one at: https://bynara.id
NARA_API_KEY=

# NVIDIA NIM API key — used by `nvidia_nim/*` models (free first-party endpoints,
# far more generous than Gemini's 20/day). Get one at: https://build.nvidia.com
# Key format: starts with `nvapi-`.
NVIDIA_NIM_API_KEY=
